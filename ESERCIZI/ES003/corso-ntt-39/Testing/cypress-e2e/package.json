{
  "name": "corso-ntt-39-cypress-e2e",
  "version": "1.0.0",
  "description": "Cypress E2E tests for Spring Boot application",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:firefox": "cypress run --browser firefox",
    "cy:run:edge": "cypress run --browser edge",
    "cy:run:headed": "cypress run --headed",
    "test": "cypress run",
    "test:chrome": "cypress run --browser chrome --headed",
    "test:report": "cypress run --reporter mochawesome",
    "clean": "rm -rf cypress/screenshots cypress/videos"
  },
  "keywords": [
    "cypress",
    "e2e",
    "testing",
    "spring-boot"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^13.6.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  },
  "dependencies": {}
}
